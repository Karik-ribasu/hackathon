{
  "name": "@teachable/admin-tools-codegen",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "admin-tools-codegen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "codegen:admin-api": "npm run build && node dist/cli.js --input ../../open-api/admin-api.yaml --output ./generated/teachable-admin-tools/admin-api-tools.ts --overrides ./overrides/registry.json"
  },
  "dependencies": {
    "@teachable/admin-openapi-parser": "file:../admin-openapi-parser",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "@mastra/core": "^1.25.0"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": true
    }
  }
}
