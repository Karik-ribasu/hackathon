{
  "name": "teachable-mastra-admin",
  "version": "1.0.0",
  "description": "Mastra shell with Teachable Admin OpenAPI tools (generated).",
  "main": "index.js",
  "scripts": {
    "codegen:admin-api": "npm --prefix ../../packages/admin-tools-codegen run build && node ../../packages/admin-tools-codegen/dist/cli.js --input ../../open-api/admin-api.yaml --output ./src/mastra/tools/admin-api-tools.ts --overrides ../../packages/admin-tools-codegen/overrides/registry.json",
    "prebuild": "npm run codegen:admin-api",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "dev": "mastra dev",
    "build": "mastra build",
    "start": "mastra start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@mastra/core": "^1.25.0",
    "@mastra/duckdb": "^1.1.2",
    "@mastra/evals": "^1.2.1",
    "@mastra/libsql": "^1.8.1",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.15.1",
    "@mastra/observability": "^1.9.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@teachable/admin-openapi-parser": "file:../../packages/admin-openapi-parser",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "mastra": "^1.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
