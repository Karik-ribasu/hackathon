# Teachable Admin API (MVP): required for TeachableAdminHttpClient bootstrap.
# Copy to .env and fill with real values. Do not commit secrets.
#
# Base URL for the Admin API (no trailing slash required). There is no implicit default;
# the client fails fast if this is unset or invalid.
TEACHABLE_ADMIN_BASE_URL=https://example.teachable.com

# Value sent on every request as the X-Consumer-Custom-ID header (required).
TEACHABLE_ADMIN_CONSUMER_CUSTOM_ID=your-consumer-custom-id
